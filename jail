#!/usr/bin/env bash

set -euo pipefail

warn () {
    echo -e "\033[1;33mwarning\033[0m: $@" >&2
}

error () {
    echo -e "\033[1;31merror\033[0m: $@" >&2
}

usage () {
    cat <<'EOF'
usage: jail [options] -- command [args...]

options:
  -p, --programs LIST       expose extra programs in /bin (comma-separated)
  -b, --bind SRC:DEST:MODE  bind mount SRC at DEST; MODE must be ro or rw
  -e, --set-env NAME=VALUE  set an environment variable inside the jail
      --home PATH           alias for --set-env HOME=PATH

examples:
  jail -- emacs
  jail -p sh,printf -- emacs -nw
  jail -b /tmp:/host-tmp:rw -- sh
  jail --home /tmp -- emacs -nw
EOF
}

if [[ "$#" -eq 0 ]]
then
    usage
    exit 1
fi

extra_programs=()
custom_binds=()
custom_env=()

add_extra_programs () {
    list="$1"

    if [[ "$list" == "" ]]
    then
        error "--programs requires a comma-separated list"
        exit 1
    fi

    IFS=',' read -r -a programs <<< "$list"
    for program in "${programs[@]}"
    do
        if [[ "$program" == "" ]]
        then
            error "--programs requires a comma-separated list"
            exit 1
        fi

        extra_programs+=("$program")
    done
}

add_custom_bind () {
    spec="$1"

    if [[ "$spec" != *:*:* ]]
    then
        error "--bind requires SRC:DEST:ro|rw"
        exit 1
    fi

    src="${spec%%:*}"
    rest="${spec#*:}"

    if [[ "$rest" == *:ro ]]
    then
        mode="ro"
        dest="${rest%:ro}"
    elif [[ "$rest" == *:rw ]]
    then
        mode="rw"
        dest="${rest%:rw}"
    else
        error "--bind mode must be ro or rw"
        exit 1
    fi

    if [[ "$src" == "" || "$dest" == "" ]]
    then
        error "--bind requires SRC:DEST:ro|rw"
        exit 1
    fi

    if [[ "$dest" != /* ]]
    then
        error "--bind destination must be absolute: $dest"
        exit 1
    fi

    if [[ ! -e "$src" ]]
    then
        error "--bind source does not exist: $src"
        exit 1
    fi

    custom_binds+=("$src" "$dest" "$mode")
}

add_custom_env () {
    spec="$1"

    if [[ "$spec" != *=* ]]
    then
        error "--set-env requires NAME=VALUE"
        exit 1
    fi

    name="${spec%%=*}"
    value="${spec#*=}"

    if [[ "$name" == "" ]]
    then
        error "--set-env requires NAME=VALUE"
        exit 1
    fi

    custom_env+=("$name" "$value")
}

found_separator=0
while [[ "$#" -gt 0 ]]
do
    case "$1" in
        --)
            found_separator=1
            shift
            break
            ;;
        -p|--programs)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--programs requires a comma-separated list"
                exit 1
            fi

            add_extra_programs "$2"
            shift 2
            ;;
        -b|--bind)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--bind requires SRC:DEST:ro|rw"
                exit 1
            fi

            add_custom_bind "$2"
            shift 2
            ;;
        -e|--set-env)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--set-env requires NAME=VALUE"
                exit 1
            fi

            add_custom_env "$2"
            shift 2
            ;;
        --home)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--home requires a value"
                exit 1
            fi

            add_custom_env "HOME=$2"
            shift 2
            ;;
        --*)
            error "unknown option: $1"
            exit 1
            ;;
        *)
            error "missing -- before command"
            exit 1
            ;;
    esac
done

if [[ "$found_separator" -eq 0 ]]
then
    error "missing -- before command"
    exit 1
fi

app_name="${1:-}"

if [[ "$app_name" == "" ]]
then
    error "missing command after --"
    exit 1
fi

shift

resolve_executable () {
    executable="$1"

    if ! executable_bin=$(type -P "$executable")
    then
        error "executable not found in \$PATH: $executable"
        exit 1
    fi

    executable_path=$(realpath "$executable_bin" 2> /dev/null)
    if [[ ! -x "$executable_path" ]]
    then
        error "not an executable: ${executable_path}"
        exit 1
    fi

    printf '%s\n' "$executable_path"
}

executable_names=("$app_name" "${extra_programs[@]}")
executable_paths=()

for executable in "${executable_names[@]}"
do
    executable_paths+=("$(resolve_executable "$executable")")
done

app_path="${executable_paths[0]}"

nix_store_package_dir () {
    path="$1"

    if [[ "$path" != /nix/store/*/* ]]
    then
        return
    fi

    rest="${path#/nix/store/}"
    printf '/nix/store/%s\n' "${rest%%/*}"
}

nix_store_paths () {
    package_dir=$(nix_store_package_dir "$1")

    if [[ "$package_dir" == "" ]]
    then
        return
    fi

    if command -v nix-store > /dev/null && nix-store -qR "$package_dir" 2> /dev/null
    then
        return
    fi

    printf '%s\n' "$package_dir"
}

bw_binds=()
nix_binds=()
bound_dests=()

add_bind () {
    mode="$1"
    src="$2"
    dest="$3"

    if [[ "$mode" == "ro" ]]
    then
        bind_arg="--ro-bind"
    else
        bind_arg="--bind"
    fi

    for bound_dest in "${bound_dests[@]}"
    do
        if [[ "$dest" == "$bound_dest" ]]
        then
            return
        fi
    done

    bound_dests+=("$dest")
    bw_binds+=("$bind_arg" "$src" "$dest")
}

is_under_nix_bind () {
    path="$1"

    for nix_bind in "${nix_binds[@]}"
    do
        if [[ "$path" == "$nix_bind" || "$path" == "$nix_bind"/* ]]
        then
            return 0
        fi
    done

    return 1
}

bw_args=(
    --unshare-all
    # --new-session
    --clearenv
    --setenv TERM "${TERM:-}"
    --setenv PATH /bin
    --as-pid-1
    --cap-drop ALL
    --proc /proc
    --dev /dev
    --dir /tmp
)

for ((i = 0; i < ${#custom_env[@]}; i += 2))
do
    bw_args+=(--setenv "${custom_env[$i]}" "${custom_env[$((i + 1))]}")
done

for i in "${!executable_names[@]}"
do
    executable_name="${executable_names[$i]}"
    executable_path="${executable_paths[$i]}"

    add_bind ro "$executable_path" "/bin/${executable_name}"

    while IFS= read -r path
    do
        nix_binds+=("$path")
        add_bind ro "$path" "$path"
    done < <(nix_store_paths "$executable_path" | sort -u)
done


ldd_paths () {
    bin_path="$1"

    { ldd "$bin_path" 2> /dev/null || true; } | while read -r line
    do
        if [[ "$line" != *"=>"* ]]
        then
            continue
        fi
        left=$(echo "$line" | awk '{print $1}')
        right=$(echo "$line" | awk '{print $3}')

        if [[ "$left" == /* ]]
        then
            echo "$left"
        fi

        if [[ "$right" == /* ]]
        then
            echo "$right"
        fi
    done
}


for executable_path in "${executable_paths[@]}"
do
    while IFS= read -r lib
    do
        if is_under_nix_bind "$lib"
        then
            continue
        fi

        add_bind ro "$lib" "$lib"
    done < <(ldd_paths "$executable_path" | sort -u)
done

for ((i = 0; i < ${#custom_binds[@]}; i += 3))
do
    add_bind "${custom_binds[$((i + 2))]}" "${custom_binds[$i]}" "${custom_binds[$((i + 1))]}"
done

# echo "$bw_args"
# exit

bwrap "${bw_binds[@]}" "${bw_args[@]}" "/bin/${app_name}" "$@"
