#!/usr/bin/env bash

set -euo pipefail

warn () {
    echo -e "\033[1;33mwarning\033[0m: $@" >&2
}

error () {
    echo -e "\033[1;31merror\033[0m: $@" >&2
}

usage () {
    cat <<'EOF'
usage: jail [options] -- command [args...]

options:
  -p PROGRAM          expose extra program in /bin
  -b SRC:DEST:MODE    bind mount SRC at DEST; MODE must be ro or rw
  -B SRC:MODE         bind mount SRC at same path; MODE must be ro or rw
  -d DEVICE           expose /dev/DEVICE inside the jail
  -e NAME=VALUE       set an environment variable inside the jail
  -E NAME             copy environment variable from host into the jail
  --wd PATH           change working directory inside the jail
  --share-wd MODE     bind current directory at same path; MODE must be ro or rw
  --home PATH         alias for -e HOME=PATH
  --share-home MODE   bind user's HOME into the jail and set HOME; MODE must be ro or rw

examples:
  jail -- emacs
  jail -p sh -p printf -- emacs -nw
  jail -b /tmp:/host-tmp:rw -- sh
  jail --wd /tmp -- sh
  jail --share-wd rw -- sh
  jail --home /tmp -- emacs -nw
  jail --share-home ro -- emacs -nw
EOF
}

if [[ "$#" -eq 0 ]]
then
    usage >&2
    exit 1
fi

extra_programs=()
custom_binds=()
custom_devices=()
default_devices=(null zero random urandom tty)
custom_env=()
working_directory=""
shared_working_directory=0
shared_home_directory=0
home_directory=""
custom_home=0

add_extra_program () {
    program="$1"

    if [[ "$program" == "" ]]
    then
        error "-p requires a program name"
        exit 1
    fi

    extra_programs+=("$program")
}

add_custom_bind () {
    spec="$1"

    if [[ "$spec" != *:*:* ]]
    then
        error "-b requires SRC:DEST:ro|rw"
        exit 1
    fi

    src="${spec%%:*}"
    rest="${spec#*:}"

    if [[ "$rest" == *:ro ]]
    then
        mode="ro"
        dest="${rest%:ro}"
    elif [[ "$rest" == *:rw ]]
    then
        mode="rw"
        dest="${rest%:rw}"
    else
        error "-b mode must be ro or rw"
        exit 1
    fi

    if [[ "$src" == "" || "$dest" == "" ]]
    then
        error "-b requires SRC:DEST:ro|rw"
        exit 1
    fi

    if [[ "$dest" != /* ]]
    then
        error "-b destination must be absolute: $dest"
        exit 1
    fi

    if [[ ! -e "$src" ]]
    then
        error "-b source does not exist: $src"
        exit 1
    fi

    custom_binds+=("$src" "$dest" "$mode")
}

add_same_path_bind () {
    spec="$1"

    if [[ "$spec" != *:* ]]
    then
        error "-B requires SRC:ro|rw"
        exit 1
    fi

    src="${spec%:*}"
    mode="${spec##*:}"

    add_custom_bind "$src:$src:$mode"
}

add_device () {
    device="$1"

    if [[ "$device" == "" ]]
    then
        error "-d requires a device name"
        exit 1
    fi

    if [[ "$device" == /* ]]
    then
        error "-d expects a device name without /dev/: $device"
        exit 1
    fi

    if [[ "$device" == *..* ]]
    then
        error "-d device name cannot contain '..': $device"
        exit 1
    fi

    if [[ ! -e "/dev/$device" ]]
    then
        error "-d device does not exist: /dev/$device"
        exit 1
    fi

    custom_devices+=("$device")
}

add_working_directory_bind () {
    mode="$1"

    if [[ "$mode" != "ro" && "$mode" != "rw" ]]
    then
        error "--share-wd mode must be ro or rw"
        exit 1
    fi

    wd="$(pwd)"
    shared_working_directory=1
    custom_binds+=("$wd" "$wd" "$mode")
}

add_home_directory_bind () {
    mode="$1"

    if [[ "$mode" != "ro" && "$mode" != "rw" ]]
    then
        error "--share-home mode must be ro or rw"
        exit 1
    fi

    home="${HOME:-}"
    if [[ "$home" == "" ]]
    then
        error "--share-home requires HOME to be set"
        exit 1
    fi

    shared_home_directory=1
    home_directory="$home"
    custom_binds+=("$home" "$home" "$mode")
    add_custom_env "HOME=$home"
}

add_custom_env () {
    spec="$1"

    if [[ "$spec" != *=* ]]
    then
        error "-e requires NAME=VALUE"
        exit 1
    fi

    name="${spec%%=*}"
    value="${spec#*=}"

    if [[ "$name" == "" ]]
    then
        error "-e requires NAME=VALUE"
        exit 1
    fi

    custom_env+=("$name" "$value")
}

add_host_env () {
    name="$1"

    if [[ ! "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
    then
        error "-E requires a valid environment variable name"
        exit 1
    fi

    if [[ ! -v "$name" ]]
    then
        error "-E environment variable is not set: $name"
        exit 1
    fi

    add_custom_env "$name=${!name}"
}

found_separator=0
while [[ "$#" -gt 0 ]]
do
    case "$1" in
        --)
            found_separator=1
            shift
            break
            ;;
        -p)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-p requires a program name"
                exit 1
            fi

            add_extra_program "$2"
            shift 2
            ;;
        -b)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-b requires SRC:DEST:ro|rw"
                exit 1
            fi

            add_custom_bind "$2"
            shift 2
            ;;
        -B)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-B requires SRC:ro|rw"
                exit 1
            fi

            add_same_path_bind "$2"
            shift 2
            ;;
        -d)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-d requires a device name"
                exit 1
            fi

            add_device "$2"
            shift 2
            ;;
        -e)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-e requires NAME=VALUE"
                exit 1
            fi

            add_custom_env "$2"
            shift 2
            ;;
        -E)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-E requires an environment variable name"
                exit 1
            fi

            add_host_env "$2"
            shift 2
            ;;
        --home)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--home requires a value"
                exit 1
            fi

            custom_home=1
            home_directory="$2"
            add_custom_env "HOME=$2"
            shift 2
            ;;
        --share-home)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--share-home requires ro or rw"
                exit 1
            fi

            add_home_directory_bind "$2"
            shift 2
            ;;
        --share-wd)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--share-wd requires ro or rw"
                exit 1
            fi

            add_working_directory_bind "$2"
            shift 2
            ;;
        --wd)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "--wd requires a path"
                exit 1
            fi

            if [[ "$2" != /* ]]
            then
                error "--wd path must be absolute: $2"
                exit 1
            fi

            working_directory="$2"
            shift 2
            ;;
        --*)
            error "unknown option: $1"
            exit 1
            ;;
        *)
            error "missing -- before command"
            exit 1
            ;;
    esac
done

if [[ "$found_separator" -eq 0 ]]
then
    error "missing -- before command"
    exit 1
fi

if [[ "$working_directory" != "" && "$shared_working_directory" -eq 1 ]]
then
    error "--wd and --share-wd cannot be used together"
    exit 1
fi

if [[ "$custom_home" -eq 1 && "$shared_home_directory" -eq 1 ]]
then
    error "--home and --share-home cannot be used together"
    exit 1
fi

if [[ "$home_directory" != "" && "$working_directory" == "" ]]
then
    working_directory="$home_directory"
fi

if [[ "$working_directory" == "" ]]
then
    working_directory="/"
fi

app_name="${1:-}"

if [[ "$app_name" == "" ]]
then
    error "missing command after --"
    exit 1
fi

shift

resolve_executable () {
    executable="$1"

    if ! executable_bin=$(type -P "$executable")
    then
        error "executable not found in \$PATH: $executable"
        exit 1
    fi

    executable_path=$(realpath "$executable_bin" 2> /dev/null)
    if [[ ! -x "$executable_path" ]]
    then
        error "not an executable: ${executable_path}"
        exit 1
    fi

    printf '%s\n' "$executable_path"
}

executable_names=("$app_name" sh "${extra_programs[@]}")
executable_paths=()

for executable in "${executable_names[@]}"
do
    executable_paths+=("$(resolve_executable "$executable")")
done

app_path="${executable_paths[0]}"

nix_store_package_dir () {
    path="$1"

    if [[ "$path" != /nix/store/*/* ]]
    then
        return
    fi

    rest="${path#/nix/store/}"
    printf '/nix/store/%s\n' "${rest%%/*}"
}

nix_store_paths () {
    package_dir=$(nix_store_package_dir "$1")

    if [[ "$package_dir" == "" ]]
    then
        return
    fi

    if command -v nix-store > /dev/null && nix-store -qR "$package_dir" 2> /dev/null
    then
        return
    fi

    printf '%s\n' "$package_dir"
}

bw_binds=()
nix_binds=()
bound_dests=()

add_bind () {
    mode="$1"
    src="$2"
    dest="$3"

    if [[ "$mode" == "ro" ]]
    then
        bind_arg="--ro-bind"
    else
        bind_arg="--bind"
    fi

    for bound_dest in "${bound_dests[@]}"
    do
        if [[ "$dest" == "$bound_dest" ]]
        then
            return
        fi
    done

    bound_dests+=("$dest")
    bw_binds+=("$bind_arg" "$src" "$dest")
}

add_dev_bind () {
    device="$1"
    src="/dev/$device"
    dest="/dev/$device"

    for bound_dest in "${bound_dests[@]}"
    do
        if [[ "$dest" == "$bound_dest" ]]
        then
            return
        fi
    done

    bound_dests+=("$dest")
    bw_binds+=(--dev-bind "$src" "$dest")
}

is_under_nix_bind () {
    path="$1"

    for nix_bind in "${nix_binds[@]}"
    do
        if [[ "$path" == "$nix_bind" || "$path" == "$nix_bind"/* ]]
        then
            return 0
        fi
    done

    return 1
}

bw_args=(
    --unshare-all
    --clearenv
    --setenv TERM "${TERM:-}"
    --setenv PATH /bin
    --as-pid-1
    --cap-drop ALL
    --proc /proc
    --dir /tmp
    --chdir "$working_directory"
)

for device in "${default_devices[@]}"
do
    add_dev_bind "$device"
done

for device in "${custom_devices[@]}"
do
    add_dev_bind "$device"
done

for ((i = 0; i < ${#custom_env[@]}; i += 2))
do
    bw_args+=(--setenv "${custom_env[$i]}" "${custom_env[$((i + 1))]}")
done

for i in "${!executable_names[@]}"
do
    executable_name="${executable_names[$i]}"
    executable_path="${executable_paths[$i]}"

    add_bind ro "$executable_path" "/bin/${executable_name}"

    while IFS= read -r path
    do
        nix_binds+=("$path")
        add_bind ro "$path" "$path"
    done < <(nix_store_paths "$executable_path" | sort -u)
done


ldd_paths () {
    bin_path="$1"

    { ldd "$bin_path" 2> /dev/null || true; } | while read -r line
    do
        if [[ "$line" != *"=>"* ]]
        then
            continue
        fi
        left=$(echo "$line" | awk '{print $1}')
        right=$(echo "$line" | awk '{print $3}')

        if [[ "$left" == /* ]]
        then
            echo "$left"
        fi

        if [[ "$right" == /* ]]
        then
            echo "$right"
        fi
    done
}


for executable_path in "${executable_paths[@]}"
do
    while IFS= read -r lib
    do
        if is_under_nix_bind "$lib"
        then
            continue
        fi

        add_bind ro "$lib" "$lib"
    done < <(ldd_paths "$executable_path" | sort -u)
done

for ((i = 0; i < ${#custom_binds[@]}; i += 3))
do
    add_bind "${custom_binds[$((i + 2))]}" "${custom_binds[$i]}" "${custom_binds[$((i + 1))]}"
done

# echo "$bw_args"
# exit

restore_tty=0
tty_state=""

restore_tty_state () {
    if [[ "$restore_tty" -eq 1 ]]
    then
        stty "$tty_state" 2> /dev/null || true
    fi
}

if [[ -t 0 ]]
then
    tty_state=$(stty -g 2> /dev/null || true)

    if [[ "$tty_state" != "" ]]
    then
        restore_tty=1
        trap restore_tty_state EXIT
    fi
fi

set +e
bwrap "${bw_binds[@]}" "${bw_args[@]}" "/bin/${app_name}" "$@"
status=$?
set -e

restore_tty_state
trap - EXIT
exit "$status"
