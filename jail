#!/usr/bin/env bash

set -euo pipefail

warn () {
    echo -e "\033[1;33mwarning\033[0m: $@" >&2
}

info () {
    printf '\033[1;34minfo\033[0m: %s\n' "$*" >&2
}

error () {
    echo -e "\033[1;31merror\033[0m: $@" >&2
}

debug () {
    if [[ "${DEBUG:-}" != "" ]]
    then
        printf '\033[1;36mdebug\033[0m: %s\n' "$*" >&2
    fi
}

debug_args () {
    if [[ "${DEBUG:-}" == "" ]]
    then
        return
    fi

    local label="$1"
    local line="$label"
    local arg=""
    local quoted=""
    shift

    for arg in "$@"
    do
        printf -v quoted '%q' "$arg"
        line+=" $quoted"
    done

    debug "$line"
}

usage () {
    cat <<'EOF'
usage: jail [options] -- command [args...]

options:
  -p PROGRAM          expose extra program in /bin
  -b SRC:DEST:MODE    bind mount SRC at DEST; relative paths use host PWD
                       MODE must be ro or rw
  -B SRC:MODE         bind mount SRC at same path; relative paths use host PWD
                       MODE must be ro or rw
  -B+ SRC:MODE        like -B, and recursively bind external symlink targets
  -d DEVICE           expose /dev/DEVICE inside the jail
  -b!, -B!, -B+!, -d!, -E!
                       optional variants that ignore missing host resources
  --core              expose available coreutils programs
  --gui               expose GUI, sound, DRI devices, and driver paths
  -e NAME=VALUE       set an environment variable inside the jail
  -E NAME             copy environment variable from host into the jail
  -P NAME             persist HOME in ~/.local/share/jail.sh/profiles/NAME/home
  --net               allow access to the host network namespace

examples:
  jail -- emacs
  jail -p sh -p printf -- emacs -nw
  jail -b /tmp:/host-tmp:rw -- sh
EOF
}

if [[ "$#" -eq 0 ]]
then
    usage >&2
    exit 1
fi

extra_programs=()
custom_binds=()
custom_devices=()
custom_env=()
working_directory=""
home_directory=""
default_home=0
env_home_set=0
share_network=0
jail_runtime_dir=""
host_working_directory="$(pwd)"

cleanup_runtime_dir () {
    if [[ "$jail_runtime_dir" != "" ]]
    then
        rm -rf "$jail_runtime_dir"
    fi
}

trap cleanup_runtime_dir EXIT

for name in LANG LANGUAGE LC_ALL LC_ADDRESS LC_COLLATE LC_CTYPE LC_IDENTIFICATION LC_MEASUREMENT LC_MESSAGES LC_MONETARY LC_NAME LC_NUMERIC LC_PAPER LC_TELEPHONE LC_TIME LOCALE_ARCHIVE
do
    if [[ -v "$name" ]]
    then
        custom_env+=("$name" "${!name}")
    fi
done

host_path () {
    path="$1"

    if [[ "$path" == /* ]]
    then
        printf '%s\n' "$path"
    else
        printf '%s/%s\n' "$host_working_directory" "$path"
    fi
}

add_custom_bind () {
    spec="$1"
    optional_missing="${2:-0}"

    if [[ "$spec" != *:*:* ]]
    then
        error "-b requires SRC:DEST:ro|rw"
        exit 1
    fi

    src="${spec%%:*}"
    rest="${spec#*:}"

    if [[ "$rest" == *:ro ]]
    then
        mode="ro"
        dest="${rest%:ro}"
    elif [[ "$rest" == *:rw ]]
    then
        mode="rw"
        dest="${rest%:rw}"
    else
        error "-b mode must be ro or rw"
        exit 1
    fi

    if [[ "$src" == "" || "$dest" == "" ]]
    then
        error "-b requires SRC:DEST:ro|rw"
        exit 1
    fi

    src="$(host_path "$src")"
    dest="$(host_path "$dest")"

    if [[ ! -e "$src" ]]
    then
        if [[ "$optional_missing" -eq 1 ]]
        then
            return
        fi

        error "-b source does not exist: $src"
        exit 1
    fi

    custom_binds+=("$src" "$dest" "$mode")
}

add_device () {
    device="$1"
    optional_missing="${2:-0}"

    if [[ "$device" == "" ]]
    then
        error "-d requires a device name"
        exit 1
    fi

    if [[ "$device" == /* ]]
    then
        error "-d expects a device name without /dev/: $device"
        exit 1
    fi

    if [[ "$device" == *..* ]]
    then
        error "-d device name cannot contain '..': $device"
        exit 1
    fi

    if [[ ! -e "/dev/$device" ]]
    then
        if [[ "$optional_missing" -eq 1 ]]
        then
            return
        fi

        error "-d device does not exist: /dev/$device"
        exit 1
    fi

    custom_devices+=("$device")
}

add_custom_env () {
    spec="$1"

    if [[ "$spec" != *=* ]]
    then
        error "-e requires NAME=VALUE"
        exit 1
    fi

    name="${spec%%=*}"
    value="${spec#*=}"

    if [[ "$name" == "" ]]
    then
        error "-e requires NAME=VALUE"
        exit 1
    fi

    if [[ "$name" == HOME ]]
    then
        env_home_set=1
    fi

    custom_env+=("$name" "$value")
}

nix_store_package_dir () {
    path="$1"

    if [[ "$path" != /nix/store/* ]]
    then
        return
    fi

    rest="${path#/nix/store/}"
    printf '/nix/store/%s\n' "${rest%%/*}"
}

nix_store_paths () {
    package_dir=$(nix_store_package_dir "$1")

    if [[ "$package_dir" == "" ]]
    then
        return
    fi

    if command -v nix-store > /dev/null && nix-store -qR "$package_dir" 2> /dev/null
    then
        return
    fi

    printf '%s\n' "$package_dir"
}

path_is_under () {
    path="${1%/}"
    root="${2%/}"

    if [[ "$path" == "" ]]
    then
        path="/"
    fi

    if [[ "$root" == "" ]]
    then
        root="/"
    fi

    [[ "$path" == "$root" || ( "$root" != "/" && "$path" == "$root"/* ) ]]
}

add_nix_store_bind_args () {
    path="$1"

    while IFS= read -r nix_path
    do
        expanded_args+=(-b! "$nix_path:$nix_path:ro")
    done < <(nix_store_paths "$path" | sort -u)
}

add_bind_dependency_args () {
    target="$1"
    covered_root="${2:-}"

    if [[ "$target" == "" || "$target" == *:* || ! -e "$target" ]]
    then
        return
    fi

    if [[ "$covered_root" != "" ]] && path_is_under "$target" "$covered_root"
    then
        return
    fi

    expanded_args+=(-b! "$target:$target:ro")

    add_nix_store_bind_args "$target"
}

symlink_target () {
    link="$1"
    target=$(readlink "$link" 2> /dev/null || true)

    if [[ "$target" == "" ]]
    then
        return
    fi

    if [[ "$target" == /* ]]
    then
        printf '%s\n' "$target"
    else
        printf '%s/%s\n' "$(dirname "$link")" "$target"
    fi
}

should_scan_bind_links () {
    src="$1"

    case "$src" in
        /dev|/dev/*|/proc|/proc/*|/run|/run/*|/sys|/sys/*)
            return 1
            ;;
    esac

    return 0
}

add_bind_link_dependencies () {
    src="$1"
    covered_root="${2:-}"

    if [[ -L "$src" ]]
    then
        target=$(symlink_target "$src")
        add_bind_dependency_args "$target" "$covered_root"
    fi

    # Recursively scanning bind directories preserves symlinks that point
    # outside the bind, but it is too slow for large trees such as HOME.
    # if [[ ! -d "$src" || -L "$src" ]] || ! should_scan_bind_links "$src"
    # then
    #     return
    # fi
    #
    # while IFS= read -r link
    # do
    #     target=$(symlink_target "$link")
    #     add_bind_dependency_args "$target"
    # done < <(find "$src" -type l 2> /dev/null || true)
}

add_bind_link_dependencies_recursive () {
    src="$1"

    add_bind_link_dependencies "$src" "$src"

    if [[ ! -d "$src" || -L "$src" ]] || ! should_scan_bind_links "$src"
    then
        return
    fi

    while IFS= read -r link
    do
        target=$(symlink_target "$link")
        add_bind_dependency_args "$target" "$src"
    done < <(find "$src" -type l 2> /dev/null || true)
}

add_program_resource_args () {
    program_name="${1##*/}"

    for resource_dir in "/usr/lib/$program_name" "/usr/share/$program_name"
    do
        expanded_args+=(-b! "$resource_dir:$resource_dir:ro")
    done
}

coreutils_programs=(
    '[' b2sum base32 base64 basename basenc cat chcon chgrp chmod chown chroot
    cksum comm cp csplit cut date dd df dir dircolors dirname du echo env
    expand expr factor false fmt fold ginstall groups head hostid id join kill
    link ln logname ls md5sum mkdir mkfifo mknod mktemp mv nice nl nohup nproc
    numfmt od paste pathchk pinky pr printenv printf ptx pwd readlink realpath
    rm rmdir runcon seq sha1sum sha224sum sha256sum sha384sum sha512sum shred
    shuf sleep sort split stat stdbuf stty sum sync tac tail tee test timeout
    touch tr true truncate tsort tty uname unexpand uniq unlink uptime users vdir
    wc who whoami yes
)

add_coreutils_fallback_args () {
    found_coreutils_program=0

    for program in "${coreutils_programs[@]}"
    do
        if type -P "$program" > /dev/null
        then
            expanded_args+=(-p "$program")
            found_coreutils_program=1
        fi
    done

    if [[ "$found_coreutils_program" -eq 0 ]]
    then
        error "--core could not detect any coreutils programs in \$PATH"
        exit 1
    fi
}

add_coreutils_multicall_args () {
    coreutils_bin=$(type -P coreutils 2> /dev/null || true)
    if [[ "$coreutils_bin" == "" ]]
    then
        return 1
    fi

    coreutils_path=$(realpath "$coreutils_bin" 2> /dev/null || true)
    if [[ "$coreutils_path" == "" || ! -x "$coreutils_path" ]]
    then
        return 1
    fi

    applet_line=$(LC_ALL=C "$coreutils_path" --help 2> /dev/null | grep -A1 'Built-in program' | tail -1 || true)
    applet_line="${applet_line//[/ }"
    applet_line="${applet_line//]/ }"
    coreutils_bind_args=()

    for program in $applet_line
    do
        if [[ "$program" =~ ^(\[|[A-Za-z0-9._+-]+)$ ]]
        then
            coreutils_bind_args+=(-b! "$coreutils_path:/bin/$program:ro")
        fi
    done

    if [[ "${#coreutils_bind_args[@]}" -eq 0 ]]
    then
        return 1
    fi

    expanded_args+=(-p coreutils)
    expanded_args+=("${coreutils_bind_args[@]}")
}

add_coreutils_args () {
    if add_coreutils_multicall_args
    then
        return
    fi

    add_coreutils_fallback_args
}

add_gui_args () {
    expanded_args+=(
        -d! snd
        -d! dri
        -d! input
        -E! DBUS_SESSION_BUS_ADDRESS
        -E! XDG_RUNTIME_DIR
        -E! DISPLAY
        -E! WAYLAND_DISPLAY
        -E! XAUTHORITY
        -B! /tmp/.X11-unix:ro
        -B! /run/dbus/system_bus_socket:ro
        -B! /sys/dev:ro
        -B! /sys/devices:ro
        -B! /sys/class/input:ro
        -B! /run/udev:ro
        -B+! /etc/alsa:ro
        -B+! /etc/fonts:ro
        -B! /etc/machine-id:ro
        -B! /run/opengl-driver:ro
        -B! /run/opengl-driver-32:ro
        -B! "${XDG_RUNTIME_DIR:-}:ro"
        -B! "${XAUTHORITY:-}:ro"
    )

}

expand_meta_args () {
    expanded_args=()

    while [[ "$#" -gt 0 ]]
    do
        case "$1" in
            --)
                shift
                if [[ "${1:-}" != "" ]]
                then
                    add_program_resource_args "$1"
                fi

                expanded_args+=(--)
                expanded_args+=("$@")
                break
                ;;
            -B|-B!|-B+|-B+!)
                if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
                then
                    error "-B requires SRC:ro|rw"
                    exit 1
                fi

                bind_arg=-b
                if [[ "$1" == -B! || "$1" == -B+! ]]
                then
                    bind_arg=-b!
                fi

                src="${2%:*}"
                mode="${2##*:}"

                if [[ "$mode" != "ro" && "$mode" != "rw" ]]
                then
                    error "-B mode must be ro or rw"
                    exit 1
                fi

                if [[ "$src" == "" && ( "$1" == -B! || "$1" == -B+! ) ]]
                then
                    shift 2
                    continue
                fi

                if [[ "$src" != "" ]]
                then
                    src="$(host_path "$src")"
                fi

                expanded_args+=("$bind_arg" "$src:$src:$mode")

                if [[ -e "$src" ]]
                then
                    if [[ "$1" == -B+ || "$1" == -B+! ]]
                    then
                        add_bind_link_dependencies_recursive "$src"
                    else
                        add_bind_link_dependencies "$src"
                    fi

                    add_nix_store_bind_args "$src"
                fi

                shift 2
                ;;
            -E|-E!)
                if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
                then
                    error "-E requires an environment variable name"
                    exit 1
                fi

                name="$2"
                if [[ ! "$name" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]
                then
                    error "-E requires a valid environment variable name"
                    exit 1
                fi

                if [[ -v "$name" ]]
                then
                    expanded_args+=(-e "$name=${!name}")
                elif [[ "$1" != -E! ]]
                then
                    error "-E environment variable is not set: $name"
                    exit 1
                fi

                shift 2
                ;;
            --gui)
                add_gui_args
                shift
                ;;
            --net)
                share_network=1
                expanded_args+=(
                    -B+! /etc/hosts:ro
                    -B+! /etc/resolv.conf:ro
                    -B+! /etc/ssl/certs:ro
                    -B+! /etc/pki/ca-trust/extracted/pem/tls-ca-bundle.pem:ro
                )
                shift
                ;;
            --core)
                add_coreutils_args
                shift
                ;;
            -p)
                if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
                then
                    error "-p requires a program name"
                    exit 1
                fi

                expanded_args+=(-p "$2")
                add_program_resource_args "$2"
                shift 2
                ;;
            *)
                expanded_args+=("$1")
                shift
                ;;
        esac
    done
}

default_args=(-d null -d zero -d random -d urandom -d tty)

if [[ -v LOCALE_ARCHIVE && -e "$LOCALE_ARCHIVE" ]]
then
    default_args+=(-B+! "$LOCALE_ARCHIVE:ro")
fi

set -- "${default_args[@]}" "$@"

expand_meta_args "$@"
debug_args "expanded args pass 1:" "${expanded_args[@]}"
expand_meta_args "${expanded_args[@]}"
debug_args "expanded args pass 2:" "${expanded_args[@]}"
set -- "${expanded_args[@]}"

found_separator=0
while [[ "$#" -gt 0 ]]
do
    case "$1" in
        --)
            found_separator=1
            shift
            break
            ;;
        -p)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-p requires a program name"
                exit 1
            fi

            extra_programs+=("$2")
            shift 2
            ;;
        -b|-b!)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-b requires SRC:DEST:ro|rw"
                exit 1
            fi

            optional_missing=0
            if [[ "$1" == -b! ]]
            then
                optional_missing=1
            fi

            add_custom_bind "$2" "$optional_missing"
            shift 2
            ;;
        -d|-d!)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-d requires a device name"
                exit 1
            fi

            optional_missing=0
            if [[ "$1" == -d! ]]
            then
                optional_missing=1
            fi

            add_device "$2" "$optional_missing"
            shift 2
            ;;
        -e)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-e requires NAME=VALUE"
                exit 1
            fi

            add_custom_env "$2"
            shift 2
            ;;
        -P)
            if [[ "${2:-}" == "" || "${2:-}" == "--" ]]
            then
                error "-P requires a profile name"
                exit 1
            fi

            profile_name="$2"
            if [[ ! "$profile_name" =~ ^[A-Za-z0-9._-]+$ || "$profile_name" == *..* ]]
            then
                error "-P requires a simple profile name: $profile_name"
                exit 1
            fi

            if [[ "${HOME:-}" == "" ]]
            then
                error "-P requires HOME to be set"
                exit 1
            fi

            profile_host_dir="$HOME/.local/share/jail.sh/profiles/$profile_name"
            profile_host_home="$profile_host_dir/home"
            profile_jail_home_name="${USER:-user}"
            profile_jail_home_name="${profile_jail_home_name//:/_}"
            profile_jail_home_name="${profile_jail_home_name//\//_}"
            home_directory="/home/$profile_jail_home_name"
            if [[ -d "$profile_host_home" ]]
            then
                info "reusing existing profile $profile_name ($profile_host_dir)"
            else
                mkdir -p "$profile_host_home"
                info "using new profile $profile_name ($profile_host_dir)"
            fi

            custom_binds+=("$profile_host_home" "$home_directory" rw)
            add_custom_env "HOME=$home_directory"
            shift 2
            ;;
        --*)
            error "unknown option: $1"
            exit 1
            ;;
        *)
            error "missing -- before command"
            exit 1
            ;;
    esac
done

if [[ "$found_separator" -eq 0 ]]
then
    error "missing -- before command"
    exit 1
fi

if [[ "$home_directory" != "" && "$working_directory" == "" ]]
then
    working_directory="$home_directory"
fi

if [[ "$home_directory" == "" && "$env_home_set" -eq 0 ]]
then
    default_home=1
    default_home_name="${USER:-user}"
    default_home_name="${default_home_name//:/_}"
    default_home_name="${default_home_name//\//_}"
    home_directory="/home/$default_home_name"
    add_custom_env "HOME=$home_directory"
fi

app_name="${1:-}"

if [[ "$app_name" == "" ]]
then
    error "missing command after --"
    exit 1
fi

shift

resolve_executable () {
    executable="$1"

    if ! executable_bin=$(type -P "$executable")
    then
        error "executable not found in \$PATH: $executable"
        exit 1
    fi

    executable_path=$(realpath "$executable_bin" 2> /dev/null)
    if [[ ! -x "$executable_path" ]]
    then
        error "not an executable: ${executable_path}"
        exit 1
    fi

    printf '%s\n' "$executable_bin"
}

executable_names=("$app_name" sh "${extra_programs[@]}")
executable_bins=()
executable_paths=()
executable_aliases=()

for executable in "${executable_names[@]}"
do
    executable_bin="$(resolve_executable "$executable")"
    executable_path="$(realpath "$executable_bin" 2> /dev/null)"
    executable_bins+=("$executable_bin")
    executable_paths+=("$executable_path")

    if [[ "$executable" != */* ]]
    then
        executable_aliases+=("${executable_path%/*}/$executable")
    else
        executable_aliases+=("$executable_path")
    fi
done

app_path="${executable_paths[0]}"
app_argv0="${executable_aliases[0]}"

path_dirs=()

add_path_dir () {
    path="$1"
    dir="${path%/*}"

    if [[ "$dir" == "$path" ]]
    then
        return
    fi

    if [[ "$dir" == "" ]]
    then
        dir="/"
    fi

    for path_dir in "${path_dirs[@]}"
    do
        if [[ "$dir" == "$path_dir" ]]
        then
            return
        fi
    done

    path_dirs+=("$dir")
}

for executable_path in "${executable_paths[@]}"
do
    add_path_dir "$executable_path"
done

for executable_alias in "${executable_aliases[@]}"
do
    add_path_dir "$executable_alias"
done

for executable_bin in "${executable_bins[@]}"
do
    add_path_dir "$executable_bin"
done

add_path_dir /bin/sh

jail_path=""
for path_dir in "${path_dirs[@]}"
do
    if [[ "$jail_path" == "" ]]
    then
        jail_path="$path_dir"
    else
        jail_path="$jail_path:$path_dir"
    fi
done

debug "main executable: ${executable_names[0]} -> ${executable_paths[0]}"

bw_binds=()
nix_binds=()
bound_dests=()
ld_library_path_dirs=()

add_bind () {
    mode="$1"
    src="$2"
    dest="$3"

    case "$mode" in
        ro) bind_arg="--ro-bind" ;;
        rw) bind_arg="--bind" ;;
        dev) bind_arg="--dev-bind" ;;
    esac

    for bound_dest in "${bound_dests[@]}"
    do
        if [[ "$dest" == "$bound_dest" ]]
        then
            return
        fi
    done

    bound_dests+=("$dest")
    bw_binds+=("$bind_arg" "$src" "$dest")
}

add_user_database_binds () {
    jail_runtime_dir=$(mktemp -d)

    uid=$(id -u)
    gid=$(id -g)
    user="${USER:-user}"
    group="$user"
    effective_home="${home_directory:-/}"

    user="${user//:/_}"
    group="${group//:/_}"

    printf '%s:x:%s:%s:%s:%s:/bin/sh\n' "$user" "$uid" "$gid" "$user" "$effective_home" > "$jail_runtime_dir/passwd"
    printf '%s:x:%s:%s\n' "$group" "$gid" "$user" > "$jail_runtime_dir/group"
    printf 'passwd: files\ngroup: files\nshadow: files\nhosts: files dns\n' > "$jail_runtime_dir/nsswitch.conf"

    add_bind ro "$jail_runtime_dir/passwd" /etc/passwd
    add_bind ro "$jail_runtime_dir/group" /etc/group
    add_bind ro "$jail_runtime_dir/nsswitch.conf" /etc/nsswitch.conf
}

is_under_nix_bind () {
    path="$1"

    for nix_bind in "${nix_binds[@]}"
    do
        if [[ "$path" == "$nix_bind" || "$path" == "$nix_bind"/* ]]
        then
            return 0
        fi
    done

    return 1
}

add_ld_library_path_dir () {
    lib="$1"
    dir="${lib%/*}"

    if [[ "$dir" == "$lib" || "$dir" == "" ]]
    then
        return
    fi

    for ld_library_path_dir in "${ld_library_path_dirs[@]}"
    do
        if [[ "$dir" == "$ld_library_path_dir" ]]
        then
            return
        fi
    done

    ld_library_path_dirs+=("$dir")
}

add_ld_library_path_value () {
    value="$1"
    dirs=()
    IFS=: read -r -a dirs <<< "$value"

    for dir in "${dirs[@]}"
    do
        if [[ "$dir" == "" ]]
        then
            continue
        fi

        add_ld_library_path_dir "$dir/lib"
    done
}

set_custom_env () {
    name="$1"
    value="$2"
    replaced=0

    for ((i = 0; i < ${#custom_env[@]}; i += 2))
    do
        if [[ "${custom_env[$i]}" == "$name" ]]
        then
            if [[ "$replaced" -eq 0 ]]
            then
                custom_env[$((i + 1))]="$value"
                replaced=1
            else
                custom_env[$i]=""
            fi
        fi
    done

    if [[ "$replaced" -eq 0 ]]
    then
        custom_env+=("$name" "$value")
    fi
}

bw_args=(
    --unshare-all
    --clearenv
    --setenv TERM "${TERM:-}"
    --setenv PATH "$jail_path"
    --as-pid-1
    --cap-drop ALL
    --proc /proc
    --dir /tmp
    --tmpfs /dev/shm
    --symlink /proc/self/fd /dev/fd
    --symlink /proc/self/fd/0 /dev/stdin
    --symlink /proc/self/fd/1 /dev/stdout
    --symlink /proc/self/fd/2 /dev/stderr
)

if [[ "$working_directory" != "" ]]
then
    bw_args+=(--chdir "$working_directory")
fi

if [[ "$default_home" -eq 1 ]]
then
    bw_args+=(--dir /home --dir "$home_directory")
fi

if [[ "$share_network" -eq 1 ]]
then
    bw_args+=(--share-net)
fi

for device in "${custom_devices[@]}"
do
    add_bind dev "/dev/$device" "/dev/$device"
done

add_user_database_binds

for i in "${!executable_names[@]}"
do
    executable_name="${executable_names[$i]}"
    executable_bin="${executable_bins[$i]}"
    executable_path="${executable_paths[$i]}"
    executable_alias="${executable_aliases[$i]}"

    add_bind ro "$executable_path" "$executable_path"

    if [[ "$executable_alias" != "$executable_path" ]]
    then
        add_bind ro "$executable_path" "$executable_alias"
    fi

    if [[ "$executable_bin" != "$executable_path" ]]
    then
        add_bind ro "$executable_path" "$executable_bin"
    fi

    if [[ "$executable_name" == sh ]]
    then
        add_bind ro "$executable_path" /bin/sh
    fi

    while IFS= read -r path
    do
        nix_binds+=("$path")
        if [[ "$i" -eq 0 ]]
        then
            debug "Nix dependency for $executable_name: $path"
        fi
        add_bind ro "$path" "$path"
    done < <(nix_store_paths "$executable_path" | sort -u)
done


ldd_paths () {
    bin_path="$1"

    { ldd "$bin_path" 2> /dev/null || true; } | while read -r line
    do
        left=$(echo "$line" | awk '{print $1}')
        right=""

        if [[ "$line" == *"=>"* ]]
        then
            right=$(echo "$line" | awk '{print $3}')
        fi

        if [[ "$left" == /* ]]
        then
            echo "$left"
        fi

        if [[ "$right" == /* ]]
        then
            echo "$right"
        fi
    done
}


for i in "${!executable_paths[@]}"
do
    executable_name="${executable_names[$i]}"
    executable_path="${executable_paths[$i]}"

    while IFS= read -r lib
    do
        if is_under_nix_bind "$lib"
        then
            if [[ "$i" -eq 0 ]]
            then
                debug "library dependency for $executable_name covered by Nix bind: $lib"
            fi
            continue
        fi

        if [[ "$i" -eq 0 ]]
        then
            debug "library dependency for $executable_name: $lib"
        fi
        add_ld_library_path_dir "$lib"
        add_bind ro "$lib" "$lib"
    done < <(ldd_paths "$executable_path" | sort -u)
done

if [[ "${#ld_library_path_dirs[@]}" -gt 0 ]]
then
    for ((i = 0; i < ${#custom_env[@]}; i += 2))
    do
        if [[ "${custom_env[$i]}" == LD_LIBRARY_PATH ]]
        then
            add_ld_library_path_value "${custom_env[$((i + 1))]}"
        fi
    done

    ld_library_path=""
    for ld_library_path_dir in "${ld_library_path_dirs[@]}"
    do
        if [[ "$ld_library_path" == "" ]]
        then
            ld_library_path="$ld_library_path_dir"
        else
            ld_library_path="$ld_library_path:$ld_library_path_dir"
        fi
    done

    debug "LD_LIBRARY_PATH: $ld_library_path"
    set_custom_env LD_LIBRARY_PATH "$ld_library_path"
fi

for ((i = 0; i < ${#custom_env[@]}; i += 2))
do
    if [[ "${custom_env[$i]}" == "" ]]
    then
        continue
    fi

    bw_args+=(--setenv "${custom_env[$i]}" "${custom_env[$((i + 1))]}")
done

for ((i = 0; i < ${#custom_binds[@]}; i += 3))
do
    add_bind "${custom_binds[$((i + 2))]}" "${custom_binds[$i]}" "${custom_binds[$((i + 1))]}"
done

# echo "$bw_args"
# exit

restore_tty=0
tty_state=""

restore_tty_state () {
    if [[ "$restore_tty" -eq 1 ]]
    then
        stty "$tty_state" 2> /dev/null || true
    fi
}

cleanup () {
    restore_tty_state
    cleanup_runtime_dir
}

trap cleanup EXIT

if [[ -t 0 ]]
then
    tty_state=$(stty -g 2> /dev/null || true)

    if [[ "$tty_state" != "" ]]
    then
        restore_tty=1
    fi
fi

set +e
bwrap "${bw_binds[@]}" "${bw_args[@]}" --argv0 "$app_argv0" "$app_path" "$@"
status=$?
set -e

cleanup
trap - EXIT
exit "$status"
