#!/usr/bin/env bash

set -euo pipefail

warn () {
    echo -e "\033[1;33mwarning\033[0m: $@" >&2
}

error () {
    echo -e "\033[1;31merror\033[0m: $@" >&2
}

app_name="${1:-}"

if [[ "$app_name" == "" ]]
then
    error "you have to pass an app to be jailed"
    exit 1
fi

shift

if ! app_bin=$(type -P "${app_name}")
then
    error "${app_name} not found in \$PATH"
    exit 1
fi

app_path=$(realpath "${app_bin}" 2> /dev/null)
if [[ ! -x "$app_path" ]]
then
    error "not an executable: ${app_path}"
    exit 1
fi

nix_store_package_dir () {
    path="$1"

    if [[ "$path" != /nix/store/*/* ]]
    then
        return
    fi

    rest="${path#/nix/store/}"
    printf '/nix/store/%s\n' "${rest%%/*}"
}

nix_store_paths () {
    package_dir=$(nix_store_package_dir "$1")

    if [[ "$package_dir" == "" ]]
    then
        return
    fi

    if command -v nix-store > /dev/null && nix-store -qR "$package_dir" 2> /dev/null
    then
        return
    fi

    printf '%s\n' "$package_dir"
}

bw_binds=()
nix_binds=()

bw_args=(
    --unshare-all
    --new-session
    --as-pid-1
    --cap-drop ALL
    --ro-bind "$app_path" "/bin/${app_name}"
    --proc /proc
    --dev /dev
    --dir /tmp
)

while IFS= read -r path
do
    nix_binds+=("$path")
    bw_binds+=(--ro-bind "$path" "$path")
done < <(nix_store_paths "$app_path" | sort -u)


ldd_paths () {
    ldd "${app_path}" | while read -r line
    do
        if [[ "$line" != *"=>"* ]]
        then
            continue
        fi
        left=$(echo "$line" | awk '{print $1}')
        right=$(echo "$line" | awk '{print $3}')

        if [[ "$left" == /* ]]
        then
            echo "$left"
        fi

        if [[ "$right" == /* ]]
        then
            echo "$right"
        fi
    done
}


while IFS= read -r lib
do
    for path in "${nix_binds[@]}"
    do
        [[ "$lib" == "$path" || "$lib" == "$path"/* ]] && continue 2
    done

    bw_binds+=(--ro-bind "$lib" "$lib")
done < <(ldd_paths | sort -u)

# echo "$bw_args"
# exit

bwrap "${bw_binds[@]}" "${bw_args[@]}" "/bin/${app_name}" "$@"
